# --- Cấu hình Database (Lấy từ Supabase) ---
# Format: postgres://[user]:[password]@[host]:[port]/[dbname]?sslmode=disable
DATABASE_URL=postgres://postgres.your_supabase_id:your_password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DB_MAX_CONNS=50

# --- Cấu hình Auth ---
JWT_SECRET=1234567890
JWT_TTL_MINUTES=1440
GOOGLE_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
# Optional: giới hạn domain Google Workspace
GOOGLE_HOSTED_DOMAIN=

# --- Cấu hình Server ---
PORT=8080
FRONTEND_URL=https://your-frontend-domain.com
ALLOWED_ORIGINS=https://your-frontend-domain.com
# Example with both apex + www:
# ALLOWED_ORIGINS=https://irisschool.io.vn,https://www.irisschool.io.vn

# Auth rate limit (fixed window)
AUTH_LOGIN_RATE_LIMIT=10
AUTH_FORGOT_PASSWORD_RATE_LIMIT=5
AUTH_RESET_PASSWORD_RATE_LIMIT=5
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_CLEANUP_EVERY=256
AUTH_RATE_LIMIT_STALE_TTL_MULTIPLIER=5

NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Cấu hình Email (Nếu dùng) ---
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
