# ===== Database Configuration =====
# PostgreSQL database name
POSTGRES_DB=iris_db

# PostgreSQL username
POSTGRES_USER=postgres

# PostgreSQL password (CHANGE THIS IN PRODUCTION!)
POSTGRES_PASSWORD=iris

# PostgreSQL port exposed to host machine
POSTGRES_PORT=5433

# Database URL for host machine tools (psql, migrations from local)
# Points to localhost:POSTGRES_PORT
DATABASE_URL=postgres://postgres:iris@localhost:5433/iris_db?sslmode=disable

# Database URL for Docker containers (internal network)
# Points to postgres service at internal port 5432
DATABASE_URL_DOCKER=postgres://postgres:iris@postgres:5432/iris_db?sslmode=disable

# ===== Service Ports =====
# Backend API port exposed to host
API_PORT=8080

# Frontend dev server port exposed to host
WEB_PORT=5173

# ===== JWT Configuration =====
# JWT signing secret (MUST CHANGE IN PRODUCTION! Use strong random string)
JWT_SECRET=change-me-to-strong-random-secret

# Access token lifetime in minutes (default: 1440 = 24 hours)
JWT_TTL_MINUTES=1440

# Refresh token lifetime in hours (default: 168 = 7 days)
JWT_REFRESH_TTL_HOURS=168

# ===== Database Connection Pool =====
# Maximum number of concurrent database connections
DB_MAX_CONNS=50

# ===== Auth Rate Limiting =====
# Maximum login attempts per IP per window (default: 10 requests/minute)
AUTH_LOGIN_RATE_LIMIT=10

# Maximum forgot-password requests per IP per window (default: 5 requests/minute)
AUTH_FORGOT_PASSWORD_RATE_LIMIT=5

# Maximum reset-password requests per IP per window (default: 5 requests/minute)
AUTH_RESET_PASSWORD_RATE_LIMIT=5

# Rate limit window duration in seconds (default: 60 = 1 minute)
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Cleanup interval: run cleanup after N requests (default: 256)
AUTH_RATE_LIMIT_CLEANUP_EVERY=256

# Stale entry TTL multiplier (default: 5x window = 5 minutes)
AUTH_RATE_LIMIT_STALE_TTL_MULTIPLIER=5

# ===== SMTP Configuration (Optional - for password reset emails) =====
# SMTP server hostname (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=

# SMTP server port (e.g., 587 for TLS, 465 for SSL)
SMTP_PORT=

# SMTP authentication username
SMTP_USER=

# SMTP authentication password or API key
SMTP_PASS=

# Email address shown as sender (if empty, uses SMTP_USER)
SMTP_FROM=

# Display name for sender (e.g., "Iris School System")
SMTP_FROM_NAME=

# ===== Frontend Configuration =====
# Frontend base URL (used in password reset emails)
FRONTEND_URL=http://localhost:5173

# CORS allowed origins (comma-separated for multiple origins)
# Example: http://localhost:5173,https://app.example.com
ALLOWED_ORIGINS=http://localhost:5173

# ===== Google OAuth Configuration (Optional) =====
# Enable Google Sign-In (true/false)
GOOGLE_LOGIN_ENABLED=false

# Google OAuth 2.0 Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=

# Restrict to specific Google Workspace domain (e.g., school.edu.vn)
# Leave empty to allow any Google account
GOOGLE_HOSTED_DOMAIN=

# ===== WebSocket Configuration =====
# WebSocket URL for real-time chat (OPTIONAL - auto-derived from VITE_API_URL if not set)
# Leave empty for standard setup (WebSocket on same domain as API)
# Only set this if WebSocket is on a different domain/port/path
# Development (auto): ws://localhost:8080/api/v1/chat/ws
# Production (auto): wss://your-domain.com/api/v1/chat/ws
# Custom example: wss://ws.your-domain.com/chat
VITE_WS_URL=